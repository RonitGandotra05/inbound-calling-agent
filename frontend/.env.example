# =====================================
# Multi-Tenant Calling Agent Platform
# =====================================

# Database (Neon PostgreSQL)
NEON_DB_CONNECTION_STRING=postgresql://user:password@host/database

# LLM - Cerebras
CEREBRAS_API_KEY=your_cerebras_api_key

# Embeddings - OpenAI (for knowledge base)
OPENAI_API_KEY=your_openai_api_key

# Vector Database - Pinecone
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_INDEX=calling-agent-kb

# Speech-to-Text - Whisper
WHISPER_API_KEY=your_whisper_api_key

# Text-to-Speech - DeepGram
DEEPGRAM_API_KEY=your_deepgram_api_key

# Telephony - Twilio
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# WhatsApp - UltraMessage (optional)
ULTRAMESSAGE_API_KEY=your_ultramessage_api_key

# Admin Dashboard
ADMIN_API_KEY=your_admin_api_key
ADMIN_ENABLED=true
API_BASE_URL=http://localhost:3000

# Auth
NEXTAUTH_SECRET=your_nextauth_secret
NEXTAUTH_URL=http://localhost:3000
