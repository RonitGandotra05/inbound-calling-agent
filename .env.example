# =================================================================
# Inbound Calling Agent - Common Environment Variables (.env.example)
# =================================================================
# Copy this file to .env in the root directory, or to backend/.env 
# and frontend/.env respectively.

# -----------------------------------------------------------------
# FRONTEND CONFIGURATION (Used by Next.js in /frontend)
# -----------------------------------------------------------------

# Backend API URL (the FastAPI server)
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# Auth
JWT_SECRET=change-me-in-production

# -----------------------------------------------------------------
# BACKEND CONFIGURATION (Used by FastAPI in /backend)
# -----------------------------------------------------------------

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/database

# LLM - Cerebras (Llama 3.3 70B)
CEREBRAS_API_KEY=your_cerebras_api_key

# Embeddings - OpenAI
OPENAI_API_KEY=your_openai_api_key

# Vector Database - Pinecone
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_INDEX=calling-agent-kb

# Speech-to-Text - Whisper
WHISPER_API_KEY=your_whisper_api_key

# Text-to-Speech - DeepGram
DEEPGRAM_API_KEY=your_deepgram_api_key

# Telephony - Twilio
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
