# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Node modules (global catch-all)
node_modules/

# ── Frontend (Next.js) ───────────────────────────────────────────────
frontend/node_modules/
frontend/.pnp
frontend/.pnp.js
frontend/.yarn/install-state.gz
frontend/coverage/
frontend/.next/
frontend/out/
frontend/build/
frontend/.eslintcache
frontend/.stylelintcache

# ── Backend (Python) ─────────────────────────────────────────────────
backend/__pycache__/
backend/**/__pycache__/
backend/*.pyc
backend/.pytest_cache/
backend/venv/
backend/.venv/
backend/*.egg-info/

# ── Shared ───────────────────────────────────────────────────────────

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# System files
.DS_Store
._*
*.pem

# Editor directories
.idea
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.sublime-workspace

# Environment variables
.env
.env*.local
.env.*.local
!.env.example

# Turborepo cache
.turbo

